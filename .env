# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
APP_NAME=gatbunndhan
SERVER_PORT=9090

# ==========================================
# DATABASE CONFIGURATION (POSTGRESQL)
# ==========================================
DB_URL=jdbc:postgresql://localhost:5433/gathbandhan
DB_USERNAME=postgres
DB_PASSWORD=Pgsql@9090

# ==========================================
# FILE UPLOAD CONFIGURATION
# ==========================================
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# ==========================================
# STATIC FILE STORAGE
# ==========================================
UPLOAD_DIR=uploads/