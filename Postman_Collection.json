{
  "info": {
    "_postman_id": "mobile-otp-verification",
    "name": "Mobile OTP Verification API",
    "description": "Complete OTP verification flow testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+919876543210\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:9090/api/users/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "register"
              ]
            },
            "description": "Register new user - Sends email verification token and OTP to phone"
          }
        },
        {
          "name": "2. Send OTP",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:9090/api/users/send-otp?phone=%2B919876543210",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "send-otp"
              ],
              "query": [
                {
                  "key": "phone",
                  "value": "+919876543210"
                }
              ]
            },
            "description": "Send OTP to phone number (check console for OTP)"
          }
        },
        {
          "name": "3. Verify OTP",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:9090/api/users/verify-otp?phone=%2B919876543210&otp=123456",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "verify-otp"
              ],
              "query": [
                {
                  "key": "phone",
                  "value": "+919876543210"
                },
                {
                  "key": "otp",
                  "value": "123456",
                  "disabled": false
                }
              ]
            },
            "description": "Verify OTP - Replace 123456 with actual OTP from console"
          }
        },
        {
          "name": "4. Resend OTP",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:9090/api/users/resend-otp?phone=%2B919876543210",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "resend-otp"
              ],
              "query": [
                {
                  "key": "phone",
                  "value": "+919876543210"
                }
              ]
            },
            "description": "Resend OTP to phone number"
          }
        },
        {
          "name": "5. Verify Email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:9090/api/users/verify?token=YOUR_EMAIL_TOKEN_HERE",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "verify"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "YOUR_EMAIL_TOKEN_HERE"
                }
              ]
            },
            "description": "Verify email using token (check console for email verification link)"
          }
        },
        {
          "name": "6. Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:9090/api/users/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "description": "Login after email and phone verification - Returns JWT token"
          }
        }
      ],
      "description": "Complete registration and verification flow"
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:9090/api/users/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "1"
              ]
            }
          }
        },
        {
          "name": "Get User Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:9090/api/users/status/john@example.com",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "status",
                "john@example.com"
              ]
            }
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:9090/api/users/search?keyword=john",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "api",
                "users",
                "search"
              ],
              "query": [
                {
                  "key": "keyword",
                  "value": "john"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}

