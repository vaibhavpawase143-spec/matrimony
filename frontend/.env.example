# React Environment Configuration
# Copy this file to .env.local and update values

# Backend API URL
REACT_APP_API_URL=http://localhost:9090

# Razorpay Public Key (for payments)
REACT_APP_RAZORPAY_KEY_ID=rzp_test_your_key_id

# WebSocket URL for real-time chat
REACT_APP_WS_URL=ws://localhost:9090/ws

# App Configuration
REACT_APP_NAME=Matrimony App
REACT_APP_VERSION=1.0.0

# File Upload Configuration
REACT_APP_MAX_FILE_SIZE=512000000
REACT_APP_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Pagination
REACT_APP_PAGE_SIZE=20
REACT_APP_MAX_PAGES=100

# Development/Production
NODE_ENV=development

